# Required secrets
TOKEN=your_discord_bot_token
OSU_IRC_USERNAME=your_osu_username
OSU_IRC_PASSWORD=your_osu_irc_password

# osu! APIs
OSU_CLIENT_ID=your_osu_oauth_client_id
OSU_CLIENT_SECRET=your_osu_oauth_client_secret
OSU_API_KEY=your_legacy_osu_api_key

# Optional legacy fallbacks for public Discord verification settings.
# Prefer discord.welcomeChannelId and discord.verifiedRoleId in config.json.
WELCOME_CHANNEL_ID=welcome_or_verification_channel_id
VERIFIED_ROLE_ID=verified_member_role_id

# Google Sheets service-account credentials
CREDENTIALS_PATH=./google-credentials.json

# Challonge
CHALLONGE_API=your_challonge_api_key

# Private weekly availability links
STREAMER_AVAILABILITY_URL=https://example.com/streamer-availability
REFEREE_AVAILABILITY_URL=https://example.com/referee-availability
COMMS_AVAILABILITY_URL=https://example.com/commentator-availability

# Optional icon upload integration
ICON_UPLOAD_URL=https://example.com
ICON_UPLOAD_API_KEY=your_icon_upload_api_key

# Optional: load public settings from a different JSON file
# CONFIG_PATH=./config.local.json
